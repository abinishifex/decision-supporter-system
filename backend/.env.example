# Django Secret Key (Used for cryptographic signing)
# In production, this should be a long, random string!
SECRET_KEY=django-insecure-development-key-only-change-this-for-production

# Debug Mode (False in production)
DEBUG=True

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.0,0.0.0.0

# Groq API Key for the GDG AI Decision Coach
GROQ_API_KEY=your_groq_api_key_goes_here
