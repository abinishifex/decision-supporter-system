# =========================
# VITE/REACT FRONTEND
# =========================
# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Node modules
**/node_modules/
**/.npm/

# Build artifacts
**/dist
**/dist-ssr
**/*.local

# React/Vite Environments
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Vite / React caches
**/.vite/
**/.eslintcache

# =========================
# DJANGO BACKEND 
# =========================
# Python compile files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Python Virtual Environments
**/venv/
**/env/
**/.venv/
**/.env

# Local SQLite databases
**/db.sqlite3
**/db.sqlite3-journal

# Django specific
**/*.log
**/local_settings.py

# =========================
# IDEs and OS Files
# =========================
**/.vscode/
**/.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
**/*~
**/.DS_Store
**/Thumbs.db

# Backup files
**/*.zip
**/*.tar.gz
**/*.rar
**/backup/
